        m_Version: 2
        m_Title: 
        m_Contents: "\u0427\u0435\u0440\u043D\u044B\u0439 \u044D\u043A\u0440\u0430\u043D.
          \u0424\u043E\u043D\u043E\u0432\u044B\u0439 \u0437\u0432\u0443\u043A \u0441\u0443\u043F\u0435\u0440\u043C\u0430\u0440\u043A\u0435\u0442\u0430
          (\u0442\u0443-\u0434\u0443\u0443\u043D). \u0417\u0430\u0442\u0435\u043C
          \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
          \u0441\u043B\u043E\u043C\u0430\u043D\u043D\u0430\u044F \u0434\u0432\u0435\u0440\u044C
          \u0430\u0432\u0442\u043E\u0431\u0443\u0441\u0430. \u0412 \u0446\u0435\u043B\u043E\u043C,
          \u0442\u0443\u0442 \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C
          \u043F\u0435\u0440\u0435\u0434\u044B\u0448\u043A\u0430 \u0434\u043B\u044F
          \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044F"
        m_ThemeName: Classic
