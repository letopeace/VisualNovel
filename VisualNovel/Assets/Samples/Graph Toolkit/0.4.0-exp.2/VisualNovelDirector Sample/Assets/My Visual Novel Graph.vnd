    - rid: 8363499007678874501
      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u041D\u0443 \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043C \u044F
          \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u044E\u0441\u044C \u0432 \u0441\u0432\u043E\u0435\u0439
          \u043A\u043E\u043C\u043D\u0430\u0442\u0435. \u0427\u0442\u043E \u044F \u0432\u0438\u0436\u0443?
          \u041F\u043E\u0442\u043E\u043B\u043E\u043A, \u043A\u043E\u043D\u0435\u0447\u043D\u043E
          \u0436\u0435. \u0418 \u044F \u043D\u0435\u043D\u0430\u0432\u0438\u0436\u0443
          \u044D\u0442\u043E\u0442 \u043F\u043E\u0442\u043E\u043B\u043E\u043A, \u0432\u0435\u0434\u044C
          \u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043D\u0435\u0433\u043E
          \u044F \u043F\u043E\u043D\u0438\u043C\u0430\u044E. \u041F\u043E\u043D\u0438\u043C\u0430\u044E
          \u0447\u0442\u043E \u0434\u0435\u043D\u044C \u0441\u0435\u0433\u043E\u0434\u043D\u044F
          \u0432\u044B\u0434\u0430\u0441\u0442\u0441\u044F \u0442\u0430\u043A\u043E\u0439
          \u0436\u0435 \u0443\u0436\u0430\u0441\u043D\u043E\u0439 \u043A\u0430\u043A
          \u0438 \u043F\u0440\u043E\u0448\u043B\u044B\u0435 \u0434\u043D\u0438."
