    - rid: 8363499009075577752
      type: {class: SetDialogueNode, ns: Unity.GraphToolkit.Samples.VisualNovelDirector.Editor, asm: Unity.GraphToolkit.Samples.VisualNovelDirector.Editor}
      data: 
    - rid: 8363499009075577754
      type: {class: StickyNoteModel, ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Guid:
          m_Value0: 13339329349543474320
          m_Value1: 6916951681865991472
        m_HashGuid:
          serializedVersion: 2
          Hash: 90347b5d5ed11eb930c52936e8f2fd5f
        m_Version: 2
        m_Title: 
        m_Contents: "\u041F\u0440\u043E\u0445\u043E\u0434\u0438\u0442 \u0432\u0440\u0435\u043C\u044F.
          \u042F \u0445\u0437 \u043A\u0430\u043A \u044D\u0442\u043E \u0431\u0443\u0434\u0435\u0442
          \u0430\u043D\u0438\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F,
          \u043D\u043E \u0434\u0430. \u0418 \u043A\u0441\u0442\u0430\u0442\u0438.
          \u0423 \u043B\u0443\u043D\u044B \u0435\u0441\u0442\u044C \u0444\u0430\u0437\u044B.
          \u041E\u0434\u0438\u043D \u0446\u0438\u043A\u043B \u043B\u0443\u043D\u044B
          \u0434\u043B\u0438\u0442\u0441\u044F \u043F\u043E\u0447\u0442\u0438 1 \u043C\u0435\u0441\u044F\u0446.
          \u041C\u044B \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u0438 \u0441 \u043F\u043E\u043B\u043D\u043E\u043B\u0443\u043D\u0438\u044F.
          \u0412 \u0430\u043D\u0438\u043C\u0430\u0446\u0438\u0439 \u0433\u0434\u0435
          \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442 \u0432\u0440\u0435\u043C\u044F,
          \u043C\u044B \u0434\u043E\u043B\u0436\u043D\u044B \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
          \u043A\u0430\u043A \u043B\u0443\u043D\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0435\u0442
          1 \u043F\u043E\u043B\u043D\u044B\u0439 \u0446\u0438\u043A\u043B \u0438
          \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
          \u0432 \u043F\u043E\u043B\u043D\u043E\u043B\u0443\u043D\u0438\u0435."
        m_ThemeName: Classic
        m_TextSizeName: Small
        m_Position:
          serializedVersion: 2
          x: 77011.18
