        m_HashGuid:
          serializedVersion: 2
          Hash: 7843f2bcc024d0f2d6298127c9cdb538
        m_Version: 2
        m_Title: 
        m_Contents: "\u041C\u0430\u0440\u0430 \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u0435\u0442
          \u0432\u044B\u043F\u0430\u0432\u0448\u0438\u0439 \u0434\u0432\u0435\u0440\u044C,
          \u0438\u0433\u0440\u043E\u043A \u0441\u043D\u0430\u0440\u0443\u0436\u0438,
          \u043F\u043E\u043D\u0443\u0440\u044B\u0439 \u0443\u0445\u043E\u0434\u0438\u0442.
          \u0412 \u043A\u0430\u0434\u0440\u0435 \u043D\u0435\u0431\u043E, \u0433\u0434\u0435
          \u043F\u0440\u043E\u043B\u0435\u0442\u0430\u0435\u0442 \u043B\u0443\u043D\u0430
          \u0438 \u0441\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F \u0441\u043E\u043B\u043D\u0446\u0435\u043C
          \u0438 \u043B\u0443\u043D\u043E\u0439, \u0438 \u0442\u0430\u043A 2 \u0440\u0430\u0437\u0430."
        m_ThemeName: Classic
