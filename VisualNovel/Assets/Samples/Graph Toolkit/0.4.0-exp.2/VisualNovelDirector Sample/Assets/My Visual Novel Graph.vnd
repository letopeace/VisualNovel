    - rid: 8363499011799515446
      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u0427\u0435\u0433\u043E \u0432\u044B \u043D\u0430 \u043C\u0435\u043D\u044F
          \u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435? \u041C\u043E\u0436\u0435\u0442
          \u0445\u043E\u0442\u044C \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u0435
          \u043A\u0430\u043A \u0432\u044B \u0432\u043E\u043E\u0431\u0449\u0435 \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442\u0435\u0441\u044C
          \u0432\u044B\u0432\u043E\u0434\u0438\u0442\u044C \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
          \u0438\u0437 \u0436\u0435\u043B\u0443\u0434\u043A\u0430, \u0435\u0441\u043B\u0438
          \u0435\u0433\u043E \u043D\u0435\u043B\u044C\u0437\u044F \u043F\u0440\u043E\u0441\u0442\u043E
          \u0432\u044B\u0431\u043B\u0435\u0432\u0430\u0442\u044C?"
