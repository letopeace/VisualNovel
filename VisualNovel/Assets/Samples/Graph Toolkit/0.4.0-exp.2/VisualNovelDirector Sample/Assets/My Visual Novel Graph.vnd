        m_Contents: "\u0422\u0443\u0442 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u044B\u043C
          \u044D\u0444\u0444\u0435\u043A\u0442\u043E\u043C \u043C\u044B \u0438\u0437
          \u043C\u0438\u0440\u0430 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0438
          \u0434\u043E\u043B\u0436\u043D\u044B \u0440\u0435\u0437\u043A\u043E \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0442\u0438\u0441\u044C
          \u0432 \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0439 \u043C\u0438\u0440.\n\n\u041D\u0430
          \u0444\u043E\u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u0442\u044C
          \u0437\u0432\u0443\u043A \u0437\u0432\u043E\u043D\u043A\u043E\u0433\u043E
          \u0448\u0443\u043C\u0430, \u0442\u0438\u043F\u0430 \"\u0422\u0443\u0443\u0443\u0443\u043D\u043D\u043D\u043D\"\n\n\u0412
          \u043A\u0430\u0434\u0440\u0435 \u0432\u043D\u0443\u0442\u0440\u044C \u0430\u0432\u0442\u043E\u0431\u0443\u0441\u0430,
          \u041C\u0430\u0440\u0430 \u0438 \u041C\u044D\u0440\u0438. \u041C\u0430\u0440\u0430
          \u043E\u0431\u0435\u0438\u043C\u0438 \u0440\u0443\u043A\u0430\u043C\u0438
          \u0434\u0435\u0440\u0436\u0438\u0442 \u0440\u0443\u043A\u0438 \u0438\u0433\u0440\u043E\u043A\u0430.
          \u0418\u0433\u0440\u043E\u043A \u0440\u0435\u0437\u043A\u043E \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u0435\u0442\u0441\u044F."
        m_ThemeName: Classic
        m_TextSizeName: Small
        m_Position:
          serializedVersion: 2
          x: 136261.17
          y: 13478.3
          width: 200
          height: 252.46875
