    - rid: 8363499009075577635
      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u0422\u0435\u0431\u0435 \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F
          \u0435\u0449\u0435 \u0434\u043E\u043B\u0433\u043E \u0436\u0434\u0430\u0442\u044C,
          \u043F\u043E\u043A\u0430 \u043D\u0435 \u043E\u0442\u043A\u0440\u043E\u0435\u0442\u0441\u044F
          \u043E\u043A\u043E\u0448\u043A\u043E \u0433\u0434\u0435 \u044F \u0441\u043C\u043E\u0433\u0443
          \u0442\u0435\u0431\u044F \u0441\u0442\u0435\u0440\u0435\u0442\u044C. \u0418
          \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u0442\u0430\u043A\u043E\u0435
          \u043E\u043A\u043E\u0448\u043A\u043E \u0435\u0449\u0435 \u0432\u0447\u0435\u0440\u0430
          \u043F\u0440\u043E\u043B\u0435\u0442\u0435\u043B\u043E, \u0442\u0435\u0431\u0435
          \u0441\u0442\u043E\u0438\u0442 \u0437\u0430\u0431\u044B\u0442\u044C \u043E
          \u0442\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u0431\u044B\u0442\u044C
          \u0441\u0442\u0435\u0440\u0442\u044B\u043C, \u0435\u0441\u043B\u0438 \u043D\u0435
          \u0445\u043E\u0447\u0435\u0448\u044C \u0432\u0435\u0447\u043D\u043E\u0441\u0442\u044C
          \u0436\u0434\u0430\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
          \u044D\u0442\u043E\u0433\u043E \u043E\u043A\u043E\u0448\u043A\u0430."
