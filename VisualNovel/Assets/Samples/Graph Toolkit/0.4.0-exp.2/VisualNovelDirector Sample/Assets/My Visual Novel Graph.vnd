    - rid: 6958703145830056131
      type: {class: StickyNoteModel, ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Guid:
          m_Value0: 6765944642213379526
          m_Value1: 10107492979811732900
        m_HashGuid:
          serializedVersion: 2
          Hash: c6fd15f9cd76e55da4cd6e375007458c
        m_Version: 2
        m_Title: "\u0422\u0440\u044F\u0441\u043A\u0430"
        m_Contents: "\u0421\u043A\u0440\u0438\u043C\u0435\u0440. \u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F
          \u0434\u0435\u0432\u043E\u0447\u043A\u0430 \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
          \u0432 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0435
          \u0447\u0443\u0434\u0438\u0449\u0435 \u0438 \u0432\u044B\u043A\u0440\u0438\u043A\u0438\u0432\u0430\u0435\u0442,
          \"\u0418\u0441\u0447\u0435\u0437\u043D\u0438!\"\n\n\u0424\u043E\u043D \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F.
          \u043A\u0430\u043C\u0435\u0440\u0430 \u0441\u043C\u043E\u0442\u0440\u0438\u0442
          \u043E\u0442 \u0437\u0430\u0434\u043D\u0438\u0445 \u0440\u044F\u0434\u043E\u0432
          \u0432 \u0441\u0440\u0435\u0434\u043D\u0438\u0435 \u0438 \u043F\u0440\u0430\u0432\u0443\u044E
          \u0447\u0430\u0441\u0442\u044C, \u043F\u043E\u0437\u0430\u0434\u0438 \u0432\u0438\u0434\u043D\u044B
          \u043A\u0440\u0435\u0441\u043B\u0430 \u0438 \u043E\u043A\u043D\u043E. \u0423
          \u0438\u0433\u0440\u043E\u043A\u0430 \u0438\u0441\u043F\u0443\u0433\u0430\u043D\u043D\u0430\u044F
          \u0433\u0440\u0438\u043C\u0430\u0441\u0430.\n"
        m_ThemeName: Classic
        m_TextSizeName: Small
        m_Position:
          serializedVersion: 2
          x: 5280.8506
          y: 1331.1888
          width: 200
          height: 209.65637
