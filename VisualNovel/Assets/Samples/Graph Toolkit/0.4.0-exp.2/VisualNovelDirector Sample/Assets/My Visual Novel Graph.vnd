    - rid: 8363499011799515547
      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "*\u0432\u0437\u0434\u043E\u0445* \u0418\u0433\u0440\u043E\u043A,
          \u0441\u0435\u0439\u0447\u0430\u0441 \u0442\u044B \u0443\u0432\u0438\u0434\u0438\u0448\u044C
          \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F.
          \u041D\u0435 \u0441\u0432\u043E\u0438 \u0430 \u0447\u0443\u0436\u0438\u0435.
          \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0442\u0435\u0431\u0435
          \u0431\u0443\u0434\u0435\u0442 \u0431\u043E\u043B\u044C\u043D\u043E, \u0430
          \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0442\u0432\u043E\u044F
          \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0431\u0443\u0434\u0435\u0442
          \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0442\u044C\u0441\u044F
          \u0438\u0441\u0445\u043E\u0434\u044F \u0438\u0437 \u044D\u0442\u0438\u0445
          \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0438. "
