      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u041D\u043E \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
          \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044E
          \u043A \u043B\u044E\u0434\u044F\u043C. \u0422\u043E \u0435\u0441\u0442\u044C
          \u043C\u044B \u0441 \u041C\u0430\u0440\u043E\u0439 \u043D\u0435 \u043C\u043E\u0436\u0435\u043C
          \u043E\u0431\u043C\u0435\u043D\u0438\u0432\u0430\u0442\u044C\u0441\u044F
          \u0447\u0430\u0441\u0442\u0438\u0447\u043A\u0430\u043C\u0438 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0438
          \u0434\u0440\u0443\u0433 \u0441 \u0434\u0440\u0443\u0433\u043E\u043C, \u0440\u0430\u0437\u0432\u0435
          \u0447\u0442\u043E \u043E\u0442\u0434\u0430\u0432\u0430\u0442\u044C \u0432\u0441\u044E.
          \u041D\u043E \u0442\u043E\u0433\u0434\u0430 \u043A\u0442\u043E \u0442\u043E
          \u043E\u0434\u0438\u043D \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
          \u0438 \u0432\u043E\u0432\u0441\u0435 \u0431\u0435\u0437 \u043A\u0430\u043A\u0438\u0445
          \u043B\u0438\u0431\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0438."
