      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u0421\u043A\u0430\u0436\u0438, \u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C
          \u0432\u044B\u043B\u0435\u0447\u0438\u0442\u044C\u0441\u044F? \u0415\u0441\u043B\u0438
          \u0434\u0430, \u0442\u043E \u044D\u0442\u0438 \u0432\u043E\u043F\u0440\u043E\u0441\u044B
          \u043B\u0438\u0448\u044C \u0442\u044F\u043D\u0443\u0442 \u0432\u0440\u0435\u043C\u044F,
          \u0442\u0430\u043A \u0447\u0442\u043E \u0431\u0435\u0437 \u043B\u0438\u0448\u043D\u0438\u0445
          \u0441\u043B\u043E\u0432, \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0435\u043C
          \u043A \u0432\u044B\u0432\u043E\u0434\u0443 \u0438\u0437 \u0436\u0435\u043B\u0443\u0434\u043A\u0430
          \u043B\u0438\u0448\u043D\u0438\u0445... \u043E\u0439, \u0442\u043E \u0435\u0441\u0442\u044C
          \u043A\u0430\u043A\u0438\u0445 \u0442\u043E \u043A\u0440\u043E\u043C\u043E\u043A
          \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0438."
