        m_Version: 2
        m_Title: "\u0422\u0440\u044F\u0441\u043A\u0430"
        m_Contents: "\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442
          \u0442\u0440\u044F\u0441\u043A\u0430 \u043A\u0430\u043C\u0435\u0440\u044B.
          \u0418 \u0432 \u043A\u0430\u0434\u0440 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
          \u0443\u0433\u0440\u043E\u0436\u0430\u044E\u0449\u0438\u0439 \u0441\u043F\u0440\u0430\u0439\u0442
          \u041C\u044D\u0440\u0438 \u0432 \u043F\u0440\u0438\u0437\u0440\u0430\u0447\u043D\u043E\u043C
          \u043E\u0431\u043B\u0438\u0447\u0438\u0439. \u041C\u044D\u0440\u0438 \u0443\u0433\u0440\u043E\u0436\u0430\u0435\u0442
          \u0418\u0433\u0440\u043E\u043A\u0443."
