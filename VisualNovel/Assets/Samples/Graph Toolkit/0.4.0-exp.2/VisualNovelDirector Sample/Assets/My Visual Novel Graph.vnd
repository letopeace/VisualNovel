      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u041D\u0443 \u0432\u043E\u0439\u0434\u0438 \u0442\u044B \u0432
          \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435. \u0417\u0430 \u0442\u0430\u043A\u0438\u0435
          \u0434\u0435\u043D\u044C\u0433\u0438 \u043C\u044B \u0432\u0441\u0435 \u0434\u043E\u043B\u0433\u0438
          \u0441\u0435\u043C\u044C\u0438 \u0437\u0430\u043A\u0440\u043E\u0435\u043C.
          \u0422\u044B \u0436\u0435 \u043C\u0435\u0447\u0442\u0430\u043B\u0430 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0442\u044C
          \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
          \u0442\u0430\u043A? \u0412\u043E\u0442, \u043C\u044B \u0441\u043C\u043E\u0436\u0435\u043C
          \u0438 \u0435\u0433\u043E \u043E\u043F\u043B\u0430\u0442\u0438\u0442\u044C."
