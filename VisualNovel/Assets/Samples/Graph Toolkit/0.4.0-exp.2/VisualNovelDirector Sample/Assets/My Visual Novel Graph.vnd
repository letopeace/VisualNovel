        m_Version: 2
        m_Title: 
        m_Contents: "\u0422\u0438\u0448\u0438\u043D\u0430. \u041A\u0430\u0434\u0440
          \u0434\u043E \u044D\u0442\u043E\u0433\u043E \u0431\u044B\u043B \u0442\u0443\u043F\u043E
          \u0447\u0435\u0440\u043D\u044B\u043C. \u041D\u043E \u0442\u0435\u043F\u0435\u0440\u044C
          \u0432 \u043A\u0430\u0434\u0440\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
          \u043A\u043E\u043C\u043D\u0430\u0442\u0430. \u041B\u044E\u0431\u043E\u0432\u043D\u044B\u0439
          \u043E\u0442\u0435\u043B\u044C. \u0412 \u043A\u0440\u043E\u0432\u0430\u0442\u0438
          \u043B\u0435\u0436\u0438\u0442 \u0434\u0435\u0432\u0443\u0448\u043A\u0430. "
        m_ThemeName: Classic
        m_TextSizeName: Small
