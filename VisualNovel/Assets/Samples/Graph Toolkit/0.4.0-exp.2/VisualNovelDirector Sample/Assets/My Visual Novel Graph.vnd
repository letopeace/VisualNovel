    - rid: 8363499007678874570
      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u042D\u0445... \u041D\u0443, \u0432 \u043E\u0431\u0449\u0435\u043C
          \u0435\u0434\u0430. \u0422\u043E\u0436\u0435 \u0435\u0441\u0442\u044C \u0445\u043E\u0447\u0435\u0442\u0441\u044F
          \u043F\u043E \u0443\u0442\u0440\u0430\u043C, \u043D\u043E \u043B\u0435\u043D\u044C
          \u0431\u044B\u0432\u0430\u0435\u0442 \u0434\u043E\u043C\u0430 \u0447\u0442\u043E
          \u0442\u043E \u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C. \u041C\u0430\u043A\u0430\u0440\u043E\u043D\u044B
          \u0438 \u043A\u0430\u0440\u0442\u043E\u0448\u043A\u0430 \u0441\u0433\u043D\u0438\u043B\u0438
          \u0435\u0449\u0435 2 \u043C\u0435\u0441\u044F\u0446\u0430 \u043D\u0430\u0437\u0430\u0434,
          \u043D\u0430\u0434\u043E \u0431\u044B \u0438\u0445 \u043A\u0441\u0442\u0430\u0442\u0438
          \u0432\u044B\u0431\u0440\u043E\u0441\u0438\u0442\u044C... \u041D\u0443
          \u0430 \u0434\u043E\u0448\u0438\u0440\u0430\u043A \u0436\u0440\u0430\u0442\u044C...
          \u0432\u0430\u0449\u0435 \u043D\u0435 \u043E\u0445\u043E\u0442\u0430."
