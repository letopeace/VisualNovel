    - rid: 8363499009075577591
      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "\u0412\u043E\u0442 \u0438\u043C\u0435\u043D\u043D\u043E! \u0412\u0441\u0435
          \u043D\u0435 \u0442\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u0430\u043A
          \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u0438 \u043D\u0430\u043C \u043D\u0443\u0436\u043D\u043E
          \u043F\u043E\u0439\u043C\u0430\u0442\u044C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0435
          \u0432\u0440\u0435\u043C\u044F \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E.
          \u0418 \u0442\u043E \u043D\u0435 \u0444\u0430\u043A\u0442 \u0447\u0442\u043E
          \u043C\u043D\u0435 \u0443\u0434\u0430\u0441\u0442\u0441\u044F \u0442\u0435\u0431\u044F
          \u0441\u0442\u0435\u0440\u0435\u0442\u044C."
