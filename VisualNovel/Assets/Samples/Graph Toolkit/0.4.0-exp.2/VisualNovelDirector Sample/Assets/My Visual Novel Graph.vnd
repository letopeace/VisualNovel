      type: {class: 'Constant`1[[System.String, mscorlib]]', ns: Unity.GraphToolkit.Editor, asm: Unity.GraphToolkit.Internal.Editor}
      data:
        m_Value: "(\u041F\u0435\u0440\u0435\u0434\u043E \u043C\u043D\u043E\u0439
          \u0440\u0435\u0431\u0435\u043D\u043E\u043A \u0436\u0435\u043D\u0449\u0438\u043D\u044B
          \u0447\u044C\u0438 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
          \u044F \u043F\u043E\u043B\u0443\u0447\u0430\u044E. \u0425\u043E\u0442\u044F
          \u043E\u043D \u0438 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A \u0432\u0441\u0435\u0445
          \u0431\u0435\u0434 \u0434\u043B\u044F \u043D\u0435\u0435, \u043F\u043E\u0447\u0435\u043C\u0443
          \u0442\u043E \u0443 \u043C\u0435\u043D\u044F \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435,
          \u0447\u0442\u043E \u044F \u0434\u043E\u043B\u0436\u0435\u043D \u0437\u0430\u0449\u0438\u0449\u0430\u0442\u044C
          \u0435\u0433\u043E \u043D\u0435 \u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0438
          \u043D\u0430 \u0447\u0442\u043E)"
