      data:
        m_Value: "\u0422\u0435 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
          \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u044B \u0434\u0430\u043B\u0430
          \u043C\u043D\u0435, \u044F \u0438\u0445 \u043D\u0435\u043D\u0430\u0432\u0438\u0436\u0443.
          \u0418\u0437 \u0437\u0430 \u043D\u0438\u0445 \u044F \u0441\u0442\u0430\u043B
          \u0431\u043E\u044F\u0442\u044C\u0441\u044F \u0441\u043C\u0435\u0440\u0442\u0438,
          \u0438\u0437 \u0437\u0430 \u043D\u0438\u0445 \u044F \u043D\u0430\u0447\u0430\u043B
          \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C \u0442\u0435\u0445 \u043A\u0442\u043E
          \u043A\u043E\u0433\u0434\u0430 \u0442\u043E \u043E\u0431\u043E \u043C\u043D\u0435
          \u0437\u0430\u0431\u043E\u0442\u0438\u043B\u0441\u044F. \u041E\u043D\u0438
          \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043C\u043E\u0435 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435,
          \u043C\u043E\u044E \u0441\u0443\u0442\u044C. "
